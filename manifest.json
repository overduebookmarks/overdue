{
  "manifest_version": 2,
  "name": "Overdue Bookmarks",
  "version": "1.1",
  "description": "Split pane bookmark manager for Firefox",
  "permissions": ["bookmarks", "tabs"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Overdue Bookmarks",
    "default_icon": {
      "16": "icons/icon_16.png",
      "32": "icons/icon_32.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    }
  },
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "overdue@local",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}